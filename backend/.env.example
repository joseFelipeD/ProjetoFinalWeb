# Copie este arquivo para ".env" e ajuste os valores conforme necessário.

# Banco de dados (SQLite por padrão - cria o arquivo eduinsight.db na raiz do backend)
DATABASE_URL=sqlite:///./eduinsight.db

# JWT - troque por uma string aleatória e secreta em produção
SECRET_KEY=troque-esta-chave-por-um-valor-aleatorio-e-secreto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# IA (Google Gemini, opcional) - se não preenchido, o sistema usa um
# gerador heurístico local para os relatórios pedagógicos.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Origem do frontend (Vite), usada na configuração de CORS
FRONTEND_ORIGIN=http://localhost:5173
